# =============================================================================
# KillMatch Agentic Suite - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to git!
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI Configuration
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Pinecone Vector Database
# -----------------------------------------------------------------------------
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=killmatch-jobs

# -----------------------------------------------------------------------------
# GitHub API
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-github-token-here

# -----------------------------------------------------------------------------
# Tavily API (for company intelligence)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# -----------------------------------------------------------------------------
# Mistral AI (for resume parsing)
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=your-mistral-api-key-here

# -----------------------------------------------------------------------------
# Database Configuration (Cloud SQL - GCP)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@YOUR_CLOUD_SQL_IP:5432/jobskillsql
CLOUD_SQL_CONNECTION_NAME=skillmatch-492220:us-central1:jobskillsql
DB_HOST=YOUR_CLOUD_SQL_IP
DB_NAME=jobskillsql
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# MCP Server URLs
# -----------------------------------------------------------------------------
MCP_GITHUB_SERVER_URL=http://localhost:8001
MCP_JOBMARKET_SERVER_URL=http://localhost:8002

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
BACKEND_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Airflow Configuration
# -----------------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:YOUR_DB_PASSWORD@YOUR_CLOUD_SQL_IP:5432/jobskillsql

# -----------------------------------------------------------------------------
# Email Notifications (Gmail SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# -----------------------------------------------------------------------------
# AWS S3 (for resume storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_S3_BUCKET=jobzilla-storage
AWS_REGION=us-east-1
